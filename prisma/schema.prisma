// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Team {
  A
  B
}

enum RoomStatus {
  LOBBY
  PLAYING
  FINISHED
}

enum Winner {
  A
  B
  NONE
}

model Profile {
  id String @id // supabase auth uuid
  username String @unique
  createdAt DateTime @default(now())

  hostedRooms Room[] @relation("RoomHost")
  roomPlayers RoomPlayer[]
  guesses Guess[]
  drawerA Round[] @relation("DrawerA")
  drawerB Round[] @relation("DrawerB")
}

model Room {
  id String @id @default(cuid())
  code String @unique
  status RoomStatus @default(LOBBY)

  hostId String
  host Profile @relation("RoomHost", fields: [hostId], references: [id])

  currentRound Int @default(0)
  scoreA Int @default(0)
  scoreB Int @default(0)

  createdAt DateTime @default(now())

  players RoomPlayer[]
  rounds Round[]
}

model RoomPlayer {
  id String @id @default(cuid())

  roomId String
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  profileId String
  profile Profile @relation(fields: [profileId], references: [id])

  team Team?
  isReady Boolean @default(false)

  joinedAt DateTime @default(now())

  @@unique([roomId, profileId])
}

model Round {
  id String @id @default(cuid())

  roomId String
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  number Int
  
  drawerAId String
  drawerA Profile @relation("DrawerA", fields: [drawerAId], references: [id])
  drawerBId String
  drawerB   Profile @relation("DrawerB", fields: [drawerBId], references: [id])

  wordChooserTeam Team
  winner Winner @default(NONE)

  startedAt DateTime?
  endedAt DateTime?

  secret RoundSecret?
  guesses Guess[]
}

model RoundSecret {
  id String @id @default(cuid())

  roundId String @unique
  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  word String
}

model Guess {
  id String @id @default(cuid())

  roundId String
  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  profileId String
  profile Profile @relation(fields: [profileId], references: [id])

  text String
  isCorrect Boolean @default(false)

  createdAt DateTime @default(now())
}
